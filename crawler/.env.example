# 저장 방식: json(기본, 로컬 파일) | supabase (팀원이 Supabase 넘겨주면 전환)
STORAGE_BACKEND=json

# --- Supabase (STORAGE_BACKEND=supabase 일 때만 필요) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- 워크넷(work24) 오픈 API — https://www.work24.go.kr 에서 발급 ---
WORKNET_AUTH_KEY=

# --- 크롤링 동작 제어 ---
# 링커리어 카테고리별 최대 수집 페이지 수 (비우면 전체 페이지)
LINKAREER_MAX_PAGES=5
# 요청 사이 최소 간격(ms). robots.txt 의 Bingbot Crawl-delay: 1 을 기준으로 여유있게 설정
REQUEST_DELAY_MS=1200

# HTTP API 서버 포트 (server.ts)
PORT=4000
