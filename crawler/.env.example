# 저장 방식: json(기본, 로컬 파일) | supabase (팀원이 Supabase 넘겨주면 전환)
STORAGE_BACKEND=json

# --- Supabase (STORAGE_BACKEND=supabase 일 때만 필요) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- 워크넷(work24) 오픈 API — https://www.work24.go.kr 에서 발급 ---
WORKNET_AUTH_KEY=

# --- Q-net(한국산업인력공단) 국가자격시험 시행일정 API ---
# https://www.data.go.kr/data/15074408/openapi.do 에서 활용신청 후 발급되는 서비스키
QNET_SERVICE_KEY=

# --- 서울 열린데이터광장 공공서비스예약(체육시설) API ---
# https://data.seoul.go.kr/dataList/OA-2266/S/1/datasetView.do 에서 인증키 발급
SEOUL_OPENAPI_KEY=
# 수집할 자치구(콤마 구분). 서울대 학부생 대상이라 기본값 관악구
SEOUL_SPORTS_DISTRICTS=관악구

# --- 크롤링 동작 제어 ---
# 링커리어 카테고리별 최대 수집 페이지 수 (비우면 전체 페이지)
LINKAREER_MAX_PAGES=5
# 요청 사이 최소 간격(ms). robots.txt 의 Bingbot Crawl-delay: 1 을 기준으로 여유있게 설정
REQUEST_DELAY_MS=1200

# HTTP API 서버 포트 (server.ts)
PORT=4000
